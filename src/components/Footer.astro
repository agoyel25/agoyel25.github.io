---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <span class="footer-copy font-mono">© {year} Aman Goyal</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 24px 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .footer-copy,
  .footer-built {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.66rem;
    letter-spacing: 0.06em;
    color: rgba(237, 237, 237, 0.2);
  }
</style>
