---
---

<section class="hero" id="top">
  <!-- Floating gradient orbs -->
  <div class="orb orb-1" aria-hidden="true"></div>
  <div class="orb orb-2" aria-hidden="true"></div>
  <div class="orb orb-3" aria-hidden="true"></div>

  <!-- Subtle grid overlay -->
  <div class="hero-grid" aria-hidden="true"></div>

  <div class="hero-content">
    <!-- Left: text -->
    <div class="hero-left">
      <div class="hero-meta reveal">
        <div class="available-badge">
          <span class="pulse-dot" aria-hidden="true"></span>
          <span class="font-mono">Available for opportunities</span>
        </div>
      </div>

      <h1 class="hero-name font-syne reveal reveal-d1">
        Aman<br /><span class="gradient-text">Goyal</span>
      </h1>

      <p class="hero-tagline reveal reveal-d2">
        I build infrastructure that<br class="br-desktop" />ships fast and stays up.
      </p>

      <p class="hero-quip font-mono reveal reveal-d3">
        Hire me, and I promise to only break things in staging... most of the time.
      </p>

      <div class="hero-ctas reveal reveal-d4">
        <a href="#work" class="btn-primary">View My Work</a>
        <a href="#contact" class="btn-ghost">Get In Touch</a>
      </div>

      <div class="scroll-hint reveal reveal-d4" aria-hidden="true">
        <span class="font-mono">scroll</span>
        <div class="scroll-line"></div>
      </div>
    </div>

    <!-- Right: photo -->
    <div class="hero-right reveal reveal-d2">
      <div class="photo-frame">
        <img src="/aman-portfolio-pfp.jpg" alt="Aman Goyal" class="hero-photo" />
        <div class="photo-glow" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 120px 28px 80px;
  }

  /* ── Orbs ──────────────────────────── */
  .orb {
    position: absolute;
    border-radius: 9999px;
    pointer-events: none;
    will-change: transform;
  }

  .orb-1 {
    width: 720px;
    height: 720px;
    background: radial-gradient(circle at center, rgba(232, 92, 44, 0.18), transparent 70%);
    top: -220px;
    left: -160px;
    animation: float1 14s ease-in-out infinite;
  }

  .orb-2 {
    width: 560px;
    height: 560px;
    background: radial-gradient(circle at center, rgba(255, 145, 71, 0.12), transparent 70%);
    top: 60px;
    right: -130px;
    animation: float2 19s ease-in-out infinite;
  }

  .orb-3 {
    width: 420px;
    height: 420px;
    background: radial-gradient(circle at center, rgba(232, 92, 44, 0.09), transparent 70%);
    bottom: -90px;
    left: 36%;
    animation: float3 12s ease-in-out infinite;
  }

  /* ── Grid overlay ──────────────────── */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.022) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.022) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
    pointer-events: none;
  }

  /* ── Content ───────────────────────── */
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
    display: flex;
    align-items: center;
    gap: 64px;
  }

  .hero-left {
    flex: 1;
    min-width: 0;
  }

  /* ── Photo ─────────────────────────── */
  .hero-right {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .photo-frame {
    position: relative;
    width: 340px;
    height: 420px;
  }

  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    border-radius: 20px;
    display: block;
    position: relative;
    z-index: 1;
    border: 1px solid rgba(232, 92, 44, 0.25);
  }

  .photo-glow {
    position: absolute;
    inset: -1px;
    border-radius: 20px;
    background: transparent;
    box-shadow:
      0 0 60px rgba(232, 92, 44, 0.2),
      0 0 120px rgba(232, 92, 44, 0.08);
    z-index: 0;
    pointer-events: none;
  }

  /* ── Meta row ──────────────────────── */
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 28px;
  }

  /* ── Available badge ───────────────── */
  .available-badge {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: rgba(34, 197, 94, 0.08);
    border: 1px solid rgba(34, 197, 94, 0.22);
    border-radius: 50px;
    padding: 7px 16px;
  }

  .available-badge span:last-child {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: rgba(34, 197, 94, 0.9);
    text-transform: uppercase;
  }

  .pulse-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #22c55e;
    flex-shrink: 0;
    position: relative;
  }

  .pulse-dot::after {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    background: rgba(34, 197, 94, 0.35);
    animation: pulse-ring 2.2s ease-out infinite;
  }

  @keyframes pulse-ring {
    0%   { transform: scale(0.7); opacity: 0.8; }
    70%  { transform: scale(2);   opacity: 0; }
    100% { transform: scale(2);   opacity: 0; }
  }

  .hero-name {
    font-family: 'Epilogue', sans-serif;
    font-size: clamp(5.5rem, 10vw, 9rem);
    font-weight: 800;
    line-height: 0.88;
    letter-spacing: -0.035em;
    color: #f0f0f0;
    margin: 0 0 36px;
  }

  .hero-tagline {
    font-family: 'DM Sans', sans-serif;
    font-size: clamp(1.15rem, 2.2vw, 1.5rem);
    font-weight: 300;
    color: rgba(237, 237, 237, 0.55);
    line-height: 1.5;
    margin-bottom: 48px;
    max-width: 500px;
  }

  .hero-quip {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(0.72rem, 1.2vw, 0.85rem);
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 40px;
    max-width: 500px;
    line-height: 1.6;
  }

  .hero-ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 80px;
  }

  /* ── Scroll hint ───────────────────── */
  .scroll-hint {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .scroll-hint span {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(237, 237, 237, 0.2);
  }

  .scroll-line {
    width: 52px;
    height: 1px;
    background: linear-gradient(90deg, rgba(237, 237, 237, 0.2), transparent);
  }

  @media (max-width: 900px) {
    .hero-right { display: none; }
    .hero-name { font-size: clamp(5rem, 16vw, 8rem); }
  }

  @media (max-width: 640px) {
    .br-desktop { display: none; }
    .hero-name { font-size: clamp(4rem, 20vw, 6rem); }
    .hero { padding-top: 110px; }
  }
</style>
