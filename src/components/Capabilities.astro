---
const capabilities = [
  {
    index: '01',
    title: 'Cloud Infrastructure',
    desc: 'Production-grade AWS environments — VPC, ALB, ECS/Fargate, RDS, CloudFront, WAF. Blue-green CI/CD with automated rollbacks, full IaC via Terraform, and zero-downtime deploys as the baseline.',
    tags: ['AWS', 'ECS Fargate', 'Terraform', 'RDS', 'CloudFront', 'CI/CD'],
  },
  {
    index: '02',
    title: 'Backend Systems',
    desc: 'Fault-tolerant async job architectures for AI media pipelines, credit systems, and real-time orchestration. Built to handle concurrent workloads under load without degradation.',
    tags: ['Node.js', 'Redis', 'BullMQ', 'Inngest', 'PostgreSQL'],
  },
  {
    index: '03',
    title: 'AI Systems & Agents',
    desc: 'LLM-powered products built around how agents interact with software — browser-native agents that inject into and operate within live interfaces, semantic retrieval pipelines, agentic execution flows, and BYOK abstraction layers with real user traction.',
    tags: ['OpenAI', 'Gemini', 'Mistral', 'Embeddings', 'Agentic Pipelines', 'BYOK'],
  },
  {
    index: '04',
    title: 'Product Engineering',
    desc: 'Full-stack products shipped end-to-end: SaaS platforms, Chrome extensions, auth, billing, and usage metering — from first commit to live users, without a team behind me.',
    tags: ['TypeScript', 'Next.js', 'Chrome Extensions', 'Clerk', 'Payments'],
  },
];
---

<section class="capabilities" id="capabilities">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">What I Do</span>
      <h2 class="section-title font-syne">Stack. Ship.<br />Scale.</h2>
    </div>

    <div class="cap-list">
      {capabilities.map((cap, i) => (
        <div class={`cap-row reveal reveal-d${i + 1}`}>

          {/* accent bar */}
          <div class="accent-bar" aria-hidden="true" />

          {/* index */}
          <span class="cap-index font-mono">{cap.index}</span>

          {/* body */}
          <div class="cap-body">
            <div class="cap-main">
              <h3 class="cap-title font-syne">{cap.title}</h3>
              <div class="cap-tags">
                {cap.tags.map(tag => (
                  <span class="cap-tag font-mono">{tag}</span>
                ))}
              </div>
            </div>
            <p class="cap-desc">{cap.desc}</p>
          </div>

        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Section ─────────────────────────── */
  .capabilities {
    padding: 130px 28px;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 64px;
  }

  .section-title {
    font-family: 'Epilogue', sans-serif;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.025em;
    color: #f0f0f0;
    margin-top: 12px;
  }

  /* ── List container ──────────────────── */
  .cap-list {
    border-top: 1px solid rgba(255, 255, 255, 0.07);
  }

  /* ── Row ─────────────────────────────── */
  .cap-row {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 36px;
    padding: 38px 0 38px 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    transition: background 0.35s ease;
  }

  .cap-row:hover {
    background: rgba(232, 92, 44, 0.022);
  }

  /* ── Left accent bar ─────────────────── */
  .accent-bar {
    position: absolute;
    left: 0;
    top: 12%;
    height: 76%;
    width: 2px;
    border-radius: 2px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      var(--accent) 25%,
      var(--accent) 75%,
      transparent 100%
    );
    transform: scaleY(0);
    transform-origin: center;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .cap-row:hover .accent-bar {
    transform: scaleY(1);
  }

  /* ── Index ───────────────────────────── */
  .cap-index {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: rgba(232, 92, 44, 0.4);
    letter-spacing: 0.1em;
    padding-top: 8px;
    flex-shrink: 0;
    width: 26px;
    transition: color 0.3s ease;
  }

  .cap-row:hover .cap-index {
    color: rgba(232, 92, 44, 0.75);
  }

  /* ── Body ────────────────────────────── */
  .cap-body {
    flex: 1;
    min-width: 0;
  }

  .cap-main {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 28px;
    margin-bottom: 13px;
    flex-wrap: wrap;
  }

  /* ── Title ───────────────────────────── */
  .cap-title {
    font-family: 'Epilogue', sans-serif;
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.028em;
    color: rgba(240, 240, 240, 0.88);
    line-height: 1.1;
    transition: color 0.3s ease;
  }

  .cap-row:hover .cap-title {
    color: #fff;
  }

  /* ── Tags ────────────────────────────── */
  .cap-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    flex-shrink: 0;
  }

  .cap-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    padding: 3px 9px;
    border-radius: 5px;
    background: rgba(232, 92, 44, 0.07);
    color: rgba(232, 92, 44, 0.75);
    letter-spacing: 0.04em;
    border: 1px solid rgba(232, 92, 44, 0.16);
    white-space: nowrap;
    transition: background 0.25s ease, border-color 0.25s ease, color 0.25s ease;
  }

  .cap-row:hover .cap-tag {
    background: rgba(232, 92, 44, 0.13);
    border-color: rgba(232, 92, 44, 0.32);
    color: rgba(232, 92, 44, 0.95);
  }

  /* ── Description ─────────────────────── */
  .cap-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    line-height: 1.74;
    color: rgba(237, 237, 237, 0.38);
    max-width: 660px;
    transition: color 0.3s ease;
  }

  .cap-row:hover .cap-desc {
    color: rgba(237, 237, 237, 0.52);
  }

  /* ── Responsive ──────────────────────── */
  @media (max-width: 768px) {
    .cap-row {
      gap: 20px;
      padding: 30px 0 30px 18px;
    }

    .cap-main {
      flex-direction: column;
      gap: 10px;
      align-items: flex-start;
    }

    .cap-tags {
      flex-shrink: 1;
    }
  }

  @media (max-width: 480px) {
    .cap-index {
      display: none;
    }

    .cap-row {
      padding-left: 14px;
    }
  }
</style>
