---
const cases = [
  {
    label: 'AI Chrome Extension',
    title: 'Lazyapply',
    url: 'https://lazyapply.xyz',
    github: null,
    metric: '10+',
    metricLabel: 'Waitlist\nSignups',
    problem:
      'Founders doing outbound distribution on X and Reddit were forced to manually copy post context into a separate AI chat, breaking their workflow and producing generic, low-signal replies at scale.',
    built:
      'Chrome extension with content scripts that programmatically inject into live software interfaces (X and Reddit), extract structured state from the DOM, augment it with stored context, and surface AI output inside the native UI — all without modifying the host application.',
    result:
      'Organically growing waitlist of 10+ signups ahead of Chrome Web Store approval. Strong early traffic signals validate demand. Freemium credit model with usage limits and billing logic built and ready to scale on launch.',
    tags: ['Chrome Extension', 'Content Scripts', 'TypeScript', 'Prompt Engineering', 'Auth/Billing', 'Freemium'],
    screenshot: '/lazyapply_screenshot.png',
    screenshotAlt: 'Lazyapply extension UI inside Twitter/X reply composer',
  },
  {
    label: 'Open-Source AI Tool',
    title: 'BookmarkBrain',
    url: 'https://chromewebstore.google.com/detail/bookmarkbrain/akdanakbhljjkieodocegjhabdijmdjd',
    github: 'https://github.com/agoyel25/BookmarkBrain',
    metric: '50',
    metricLabel: 'Active\nUsers',
    problem:
      'Saved posts and bookmarks on X and Reddit accumulate as an unsearchable archive — no retrieval, no synthesis, and no practical way to resurface relevant content weeks later.',
    built:
      'Privacy-first Chrome extension with local-first storage architecture, semantic embeddings over saved content, natural language Q&A returning source-cited answers, and a BYOK abstraction layer supporting OpenAI, OpenRouter, and Gemini.',
    result:
      '50 active users with zero backend dependency for personal data — all storage and retrieval runs in-browser. Fully open-source and publicly shipped. Multi-provider AI support makes it model-agnostic and future-proof.',
    tags: ['Chrome Extension', 'Semantic Search', 'Embeddings', 'Vector Retrieval', 'BYOK', 'Open Source'],
    screenshot: '/bookmarkbrain.png',
    screenshotAlt: 'BookmarkBrain semantic search interface',
  },
  {
    label: 'Open-Source CLI Tool',
    title: 'packrat',
    url: null,
    github: 'https://github.com/agoyel25/Packrat',
    metric: '1-cmd',
    metricLabel: 'Full Machine\nRestore',
    problem:
      'Rebuilding a WSL environment after a reinstall meant manually hunting down dotfiles, SSH keys, shell configs, AI agent data, and package lists — with no reliable way to capture everything before wiping the machine.',
    built:
      'Go CLI with an interactive Bubbletea TUI wizard, smart category detection across SSH keys, shell configs, AI agent data, cloud credentials, and editor settings. Archives to .tar.zst via Zstandard and snapshots the package manager state alongside the backup for a full rebuild.',
    result:
      'One command to back up, one command to restore — entire WSL home directory plus package list captured in a single compressed archive. Non-interactive mode supports scripted and cron-based runs without any prompts.',
    tags: ['Go', 'Cobra', 'Bubbletea', 'Zstandard', 'TUI', 'CLI', 'Open Source'],
    screenshot: '/banner.png',
    screenshotAlt: 'packrat interactive TUI backup wizard running in terminal',
  },
  {
    label: 'AI Video SaaS',
    title: 'Vubo',
    url: 'https://vubo.ai',
    github: null,
    metric: '0',
    metricLabel: 'Downtime\non Deploys',
    problem:
      'Needed production-grade, multi-tenant AI video SaaS infrastructure built from the ground up — no existing playbook, aggressive timelines.',
    built:
      'AWS ECS Fargate + Redis/BullMQ/Inngest pipeline for AI media processing, subscription-gated credit system, CI/CD via GitHub Actions, OpenTelemetry tracing across every pipeline step.',
    result:
      'Zero-downtime deployments with automated blue-green rollouts. Full observability across AI generation workflows. System handles concurrent workloads without degradation.',
    tags: ['AWS ECS', 'Next.js', 'Redis', 'Inngest', 'BullMQ', 'GitHub Actions'],
  },
  {
    label: 'Startup Cost Reduction',
    title: 'Self-Hosted Stack',
    url: null,
    github: null,
    metric: '$6K+',
    metricLabel: 'Saved\nPer Year',
    problem:
      'Early-stage startups burning runway on SaaS analytics, live chat, uptime monitoring, and session replay tools — spending before finding product-market fit.',
    built:
      'Replaced paid SaaS with self-hosted Umami (analytics), Chatwoot (support), Uptime Kuma (monitoring), OpenReplay (session replay) on a single hardened VPS with full HTTPS/TLS.',
    result:
      'Over $6,000/year recaptured with zero functional compromise. Least-privilege access, VPN-restricted internals, environment isolation — more secure than the SaaS it replaced.',
    tags: ['Docker', 'Nginx', 'VPS', 'Umami', 'Chatwoot', 'OpenReplay'],
  },
  {
    label: 'AI Video Analysis Platform',
    title: 'ClipDecode',
    url: 'https://clipdecode.com',
    github: null,
    metric: '2',
    metricLabel: 'AI Models\nOrchestrated',
    problem:
      'Extracting meaningful insights from video content required manual review — slow, unscalable, and completely unusable for teams processing large volumes of clips.',
    built:
      '4-stage AI pipeline (download → transcription → analysis → synthesis) using Google Gemini + Mistral APIs, orchestrated via Convex scheduler with fault-tolerant retry logic and real-time state updates.',
    result:
      'Fully automated video-to-insights pipeline. Credit-based usage with tier access, idempotent Dodo Payments webhooks for zero-loss billing, and Clerk auth — shipped as a production SaaS.',
    tags: ['Next.js 15', 'Convex', 'Gemini', 'Mistral', 'TypeScript', 'Dodo Payments'],
  },
  {
    label: 'Infrastructure as Code',
    title: 'Cloud Infra Automation',
    url: null,
    github: null,
    metric: '100%',
    metricLabel: 'Infrastructure\nas Code',
    problem:
      'Manual provisioning was error-prone, non-reproducible, and created dangerous drift between staging and production environments.',
    built:
      'Modular Terraform for VPC, ALB, ECS/Fargate, RDS, CloudFront, WAF, ElastiCache. Blue-green deployments via CodeDeploy integrated with GitHub Actions and ECR workflows.',
    result:
      'Fully reproducible, secure-by-default infra with least-privilege IAM, WAF rules, and SSM secrets management. New environments spin up in minutes. Zero configuration drift.',
    tags: ['Terraform', 'AWS', 'CodeDeploy', 'CloudWatch', 'WAF', 'RDS Proxy'],
  },
];
---

<section class="case-studies" id="work">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">Work That Shipped</span>
      <h2 class="section-title font-syne">Real problems.<br />Real outcomes.</h2>
    </div>

    <div class="cases-list">
      {cases.map((c, i) => (
        <article class={`case-card reveal reveal-d${(i % 3) + 1}${c.screenshot ? ' has-screenshot' : ''}`}>

          {/* ── Top row: index + label + metric ── */}
          <div class="card-top">
            <div class="card-top-left">
              <span class="card-index font-mono">{'0' + (i + 1)}</span>
              <span class="card-label section-label">{c.label}</span>
            </div>
            <div class="card-metric">
              <span class="metric-num gradient-text font-syne">{c.metric}</span>
              <span class="metric-label font-mono" set:html={c.metricLabel.replace('\n', '<br/>')} />
            </div>
          </div>

          {/* ── Title + links ── */}
          <div class="card-title-row">
            <h3 class="card-title font-syne">{c.title}</h3>
            <div class="card-links">
              {c.url && (
                <a
                  href={c.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="card-link font-mono"
                  aria-label={`Visit ${c.title}`}
                >
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                    <path d="M2 10L10 2M10 2H4M10 2V8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  {c.url.replace('https://', '').split('/')[0]}
                </a>
              )}
              {c.github && (
                <a
                  href={c.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="card-link card-link-gh font-mono"
                  aria-label="View source on GitHub"
                >
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                  </svg>
                  GitHub
                </a>
              )}
            </div>
          </div>

          {/* ── Screenshot preview (browser chrome) ── */}
          {c.screenshot && (
            <div class="card-preview">
              <div class="preview-chrome" aria-hidden="true">
                <span class="chrome-dot dot-red" />
                <span class="chrome-dot dot-yellow" />
                <span class="chrome-dot dot-green" />
                <span class="chrome-url font-mono">
                  {c.url ? c.url.replace('https://', '').split('/')[0] : c.title.toLowerCase()}
                </span>
              </div>
              <div class="preview-img-wrap">
                <img src={c.screenshot} alt={c.screenshotAlt} loading="lazy" />
                <div class="preview-fade" aria-hidden="true" />
              </div>
            </div>
          )}

          {/* ── 3-col body ── */}
          <div class="card-body">
            <div class="card-col">
              <span class="col-label font-mono">Problem</span>
              <p>{c.problem}</p>
            </div>
            <div class="card-divider" aria-hidden="true" />
            <div class="card-col">
              <span class="col-label font-mono">What I Built</span>
              <p>{c.built}</p>
            </div>
            <div class="card-divider" aria-hidden="true" />
            <div class="card-col">
              <span class="col-label font-mono">Result</span>
              <p>{c.result}</p>
            </div>
          </div>

          {/* ── Tags ── */}
          <div class="card-footer">
            {c.tags.map((tag) => (
              <span class="cap-tag font-mono">{tag}</span>
            ))}
          </div>

        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Section ─────────────────────────── */
  .case-studies {
    padding: 130px 28px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(232, 92, 44, 0.012) 50%,
      transparent 100%
    );
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    margin-bottom: 64px;
  }

  .section-title {
    font-family: 'Epilogue', sans-serif;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.025em;
    color: #f0f0f0;
    margin-top: 12px;
  }

  .cases-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ── Card shell ──────────────────────── */
  .case-card {
    position: relative;
    padding: 36px 36px 30px;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.07);
    background: rgba(255, 255, 255, 0.02);
    overflow: hidden;
    transition:
      border-color 0.35s ease,
      background 0.35s ease,
      transform 0.35s ease;
  }

  /* left accent bar */
  .case-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 10%;
    height: 80%;
    width: 2px;
    background: linear-gradient(
      180deg,
      transparent,
      var(--accent) 30%,
      var(--accent) 70%,
      transparent
    );
    border-radius: 2px;
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .case-card:hover {
    border-color: rgba(232, 92, 44, 0.18);
    background: rgba(232, 92, 44, 0.018);
    transform: translateY(-2px);
  }

  .case-card:hover::before {
    opacity: 1;
  }

  /* ── Top row ─────────────────────────── */
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 18px;
  }

  .card-top-left {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .card-index {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    color: rgba(232, 92, 44, 0.45);
    letter-spacing: 0.08em;
    flex-shrink: 0;
  }

  /* ── Metric ──────────────────────────── */
  .card-metric {
    text-align: right;
    flex-shrink: 0;
  }

  .metric-num {
    font-family: 'Epilogue', sans-serif;
    font-size: clamp(2.4rem, 4.5vw, 3.8rem);
    font-weight: 800;
    line-height: 1;
    display: block;
    letter-spacing: -0.03em;
  }

  .metric-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(237, 237, 237, 0.25);
    display: block;
    margin-top: 4px;
    line-height: 1.55;
  }

  /* ── Title row ───────────────────────── */
  .card-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }

  .card-title {
    font-family: 'Epilogue', sans-serif;
    font-size: clamp(2rem, 3.8vw, 2.9rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #f0f0f0;
    line-height: 1;
  }

  .card-links {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    padding: 5px 11px;
    border-radius: 7px;
    border: 1px solid rgba(232, 92, 44, 0.25);
    color: var(--accent);
    background: rgba(232, 92, 44, 0.06);
    transition: border-color 0.2s, background 0.2s, opacity 0.2s;
  }

  .card-link:hover {
    border-color: rgba(232, 92, 44, 0.55);
    background: rgba(232, 92, 44, 0.12);
  }

  .card-link-gh {
    color: rgba(237, 237, 237, 0.55);
    border-color: rgba(255, 255, 255, 0.1);
    background: rgba(255, 255, 255, 0.03);
  }

  .card-link-gh:hover {
    color: rgba(237, 237, 237, 0.9);
    border-color: rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.07);
  }

  /* ── Browser chrome preview ──────────── */
  .card-preview {
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.09);
    background: #111;
    margin-bottom: 32px;
    box-shadow:
      0 4px 32px rgba(0, 0, 0, 0.4),
      0 1px 0 rgba(255, 255, 255, 0.05) inset;
  }

  .preview-chrome {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.035);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }

  .chrome-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot-red    { background: #ff5f57; }
  .dot-yellow { background: #ffbd2e; }
  .dot-green  { background: #28c840; }

  .chrome-url {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.63rem;
    color: rgba(255, 255, 255, 0.18);
    margin-left: 10px;
    letter-spacing: 0.02em;
  }

  .preview-img-wrap {
    position: relative;
    line-height: 0;
  }

  .preview-img-wrap img {
    width: 100%;
    height: auto;
    max-height: 400px;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  /* fade out bottom of screenshot */
  .preview-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 80px;
    background: linear-gradient(to bottom, transparent, rgba(17, 17, 17, 0.85));
    pointer-events: none;
  }

  /* ── 3-col body ──────────────────────── */
  .card-body {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    padding: 24px 0;
    border-top: 1px solid rgba(255, 255, 255, 0.055);
    border-bottom: 1px solid rgba(255, 255, 255, 0.055);
    margin-bottom: 20px;
  }

  .card-divider {
    width: 1px;
    background: rgba(255, 255, 255, 0.07);
    margin: 0 26px;
    align-self: stretch;
  }

  .card-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .col-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(237, 237, 237, 0.22);
  }

  .card-col p {
    font-family: 'DM Sans', sans-serif;
    font-size: 0.86rem;
    line-height: 1.72;
    color: rgba(237, 237, 237, 0.48);
  }

  /* ── Tags ────────────────────────────── */
  .card-footer {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .cap-tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.63rem;
    padding: 3px 9px;
    border-radius: 5px;
    background: rgba(232, 92, 44, 0.07);
    color: rgba(232, 92, 44, 0.8);
    letter-spacing: 0.04em;
    border: 1px solid rgba(232, 92, 44, 0.18);
    transition: background 0.2s, border-color 0.2s;
  }

  .cap-tag:hover {
    background: rgba(232, 92, 44, 0.14);
    border-color: rgba(232, 92, 44, 0.35);
  }

  /* ── Responsive ──────────────────────── */
  @media (max-width: 768px) {
    .case-card {
      padding: 24px 20px 22px;
    }

    .card-body {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .card-divider {
      width: 100%;
      height: 1px;
      margin: 18px 0;
      align-self: auto;
    }

    .card-metric { text-align: right; }

    .card-title {
      font-size: clamp(1.8rem, 7vw, 2.4rem);
    }

    .preview-img-wrap img {
      max-height: 220px;
    }
  }

  @media (max-width: 480px) {
    .card-title-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }

  @media (max-width: 640px) {
    .case-studies { padding: 80px 20px; }
  }
</style>
